{
	"name": "@vkraft/types",
	"version": "5.199.3",
	"homepage": "https://github.com/vkraft/types",
	"readme": "https://github.com/vkraft/types",
	"description": "Code-generated VK API TypeScript types",
	"type": "commonjs",
	"author": "kravets",
	"license": "MIT",
	"keywords": [
		"vk",
		"vkontakte",
		"vk-api",
		"types",
		"vkraft",
		"code-generated"
	],
	"types": "./out/index.d.ts",
	"typings": "./out/index.d.ts",
	"exports": {
		".": {
			"types": "./out/index.d.ts"
		},
		"./*": {
			"types": "./out/*.d.ts"
		}
	},
	"scripts": {
		"cicd": "bun scripts/cicd.ts",
		"jsr": "bun scripts/release-jsr.ts",
		"generate": "bun src/index.ts",
		"lint": "bunx @biomejs/biome check ./src",
		"lint:fix": "bun lint --apply",
		"test": "bun test"
	},
	"devDependencies": {
		"@biomejs/biome": "1.5.3",
		"@types/node": "^20.11.10",
		"prettier": "^3.2.4",
		"typescript": "^5.9.3"
	},
	"files": [
		"out"
	]
}
